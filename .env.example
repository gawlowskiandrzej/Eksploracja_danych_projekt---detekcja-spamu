KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# Dataset slug from the Kaggle URL, for example:
# https://www.kaggle.com/datasets/uciml/sms-spam-collection-dataset
KAGGLE_DATASET=uciml/sms-spam-collection-dataset

# Optional, useful when the dataset archive contains more than one CSV.
# KAGGLE_CSV_NAME=spam.csv

# Optional download folder.
DATA_DIR=data
